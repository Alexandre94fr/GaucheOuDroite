# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
# Recommended: add any editor/OS/tool-specific ignore rules from the Global/ templates as needed.
# See: https://github.com/github/gitignore/tree/main/Global
#
.utmp/
ProjectFiles/FrontEnd/GaucheOuDroite/[Ll]ibrary/
ProjectFiles/FrontEnd/GaucheOuDroite/[Tt]emp/
ProjectFiles/FrontEnd/GaucheOuDroite/[Oo]bj/
ProjectFiles/FrontEnd/GaucheOuDroite/[Bb]uild/
ProjectFiles/FrontEnd/GaucheOuDroite/[Bb]uilds/
ProjectFiles/FrontEnd/GaucheOuDroite/[Ll]ogs/
ProjectFiles/FrontEnd/GaucheOuDroite/[Uu]ser[Ss]ettings/
*.log

# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
*.blend1
*.blend1.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
ProjectFiles/FrontEnd/GaucheOuDroite/[Mm]emoryCaptures/

# Recordings can get excessive in size
ProjectFiles/FrontEnd/GaucheOuDroite/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
ProjectFiles/FrontEnd/GaucheOuDroite/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
*.DotSettings.user

# Visual Studio cache directory
.vs/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Mono auto generated files
mono_crash.*

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics generated file
crashlytics-build.properties

# TestRunner generated files
InitTestScene*.unity*

# Addressables default ignores, before user customizations
ProjectFiles/FrontEnd/GaucheOuDroite/ServerData
ProjectFiles/FrontEnd/GaucheOuDroite/[Aa]ssets/StreamingAssets/aa*
ProjectFiles/FrontEnd/GaucheOuDroite/[Aa]ssets/AddressableAssetsData/link.xml*
ProjectFiles/FrontEnd/GaucheOuDroite/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /Assets/AddressableAssetsData/OSX/addressables_content_state.bin
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
ProjectFiles/FrontEnd/GaucheOuDroite/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
ProjectFiles/FrontEnd/GaucheOuDroite/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
ProjectFiles/FrontEnd/GaucheOuDroite/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
ProjectFiles/FrontEnd/GaucheOuDroite/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
ProjectFiles/FrontEnd/GaucheOuDroite/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# Auto-generated cache in Assets folder
ProjectFiles/FrontEnd/GaucheOuDroite/[Aa]ssets/[Ss]ceneDependencyCache*

